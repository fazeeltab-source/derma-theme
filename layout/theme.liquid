<!doctype html>
{%- liquid
  assign iso_code  = request.locale.iso_code
  assign config_rtl  = settings.right_to_left | default: 'enable-with-list'
  assign is_rtl = false
  assign dir = 'ltr'
  if config_rtl == 'enable-with-list'
    assign iso_code_ck = iso_code | split: '-' | first | append: ';' | prepend: ';'
    assign lis_rtl = ';ae;ar;arc;bqi;ckb;dv;fa;glk;ha;he;kwh;ks;ku;mzn;nqo;pnb;ps;sd;ug;ur;yi;'
    if lis_rtl contains iso_code_ck
      assign is_rtl = true
      assign dir = 'rtl'
    endif
  elsif config_rtl == 'enable'
    assign is_rtl = true
    assign dir = 'rtl'
  endif
-%}

<html class="no-js hdt-pr-img__effect-{{ settings.effect_secondary_image }} hdt-badge__shape-{{ settings.badge_shape }} dir--{{ dir }}{% if request.design_mode %} shopify-design-mode{% endif %} {% if settings.minimal_products %} hdt-minimal-products{% endif %}{% if settings.hidden_badges %} hdt-hidden-pr-badges{% endif %}{% if settings.hidden_quickview %} hdt-hidden-pr-quickview{% endif %}{% if settings.hidden_wishlist %} hdt-hidden-pr-wishlist{% endif %}{% if settings.hidden_compare %} hdt-hidden-pr-compare{% endif %}{% if settings.uppercase_title %} hdt-pr-uppercase_title{% endif %}" lang="{{ request.locale.iso_code }}" dir="{{ dir }}">
  <head>
    {% render 'json-ld-organization' %}
    <!-- SEOAnt Speed Up Script -->{%- if shop.metafields.seoantAppSiteSpeedUpV2.switch == 1 -%}{% include 'SEOAnt-SpeedUp' %}{%- endif -%}<!-- /SEOAnt Speed Up Script -->
  <style>.er-toast{display:none!important}</style>
  <script>
  // Hide EcomRise bundle toast notification - MutationObserver override
  (function(){
    function hideErToast(){
      var t=document.querySelector('.er-toast');
      if(t){t.style.setProperty('display','none','important');}
    }
    // Run immediately
    hideErToast();
    // Watch for any changes to body that might show the toast
    var obs=new MutationObserver(function(mutations){
      mutations.forEach(function(m){
        if(m.target && m.target.classList && m.target.classList.contains('er-toast')){
          m.target.style.setProperty('display','none','important');
        }
        if(m.addedNodes){
          m.addedNodes.forEach(function(n){
            if(n.nodeType===1 && n.classList && n.classList.contains('er-toast')){
              n.style.setProperty('display','none','important');
            }
          });
        }
      });
    });
    document.addEventListener('DOMContentLoaded',function(){
      hideErToast();
      var target=document.querySelector('.er-toast')||document.body;
      obs.observe(target,{attributes:true,attributeFilter:['style','class'],childList:true,subtree:false});
      // Also observe body for er-toast being added
      obs.observe(document.body,{childList:true,subtree:true});
    });
  })();
  </script>
  <script>
  // Load BaadMay assets lazily
  (function() {
    function loadBaadmayAssets() {
      if (!document.getElementById('baadmay-css-loaded')) {
        var css = document.createElement('link');
        css.id = 'baadmay-css-loaded';
        css.rel = 'stylesheet';
        css.href = {{ 'baadmay-styles.s.min.css' | asset_url | json }};
        document.head.appendChild(css);
        var js = document.createElement('script');
        js.src = {{ 'baadmay-scripts.s.min.js' | asset_url | json }};
        js.async = true;
        document.head.appendChild(js);
      }
    }
    if (document.readyState === 'complete') { loadBaadmayAssets(); }
    else { window.addEventListener('load', loadBaadmayAssets); }
  })();
  </script>
    {%- unless template == 'product.only_config' and request.design_mode == false -%}
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
      <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 48, height: 48 }}">
    {%- endif -%}

    {%- if settings.library_font == "shopify" -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endif -%}
    {%- if settings.library_font == 'google' -%}{{ settings.embed_google_font }}{%- endif -%}
    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; {{ 'general.meta.tag' | t }} "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; {{ 'general.meta.page' | t }} {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}

    {%- liquid
      render 'social-meta-tags'
      render 'css-variables', is_rtl: is_rtl
      render 'js-variables'
      render 'scripts'
      if settings.custom_html_head != blank
        echo settings.custom_html_head
      endif
    -%}

    {{ content_for_header }}
    {%- endunless -%}
  </head>

  <body class="hdt-page-type-{{ request.page_type }}">
    {% comment %} {%- section 'product-card-configs' -%} {% endcomment %}
    {%- unless template == 'product.only_config' and request.design_mode == false -%}
    {%- if request.page_type == "index" or request.page_type == "policy" -%}
    <h1 class="hdt-hidden">{{ page_title | default: shop.name }}</h1>
    {%- endif -%}
    {%- render 's-dom-temp' -%}
    <a class="skip-to-content-link button sr-only " href="#MainContent">{{ 'accessibility.skip_to_text' | t }}</a>
    {%- sections 'header-group' -%}
    {%- endunless -%}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
      {%- if template.suffix == 'only_config' -%}
        {%- section 'color-swatch' -%}
      {%- endif -%}
    </main>

    {%- unless template == 'product.only_config' and request.design_mode == false -%}
    <footer>
      {%- sections 'footer-group' -%}
    </footer>
    {%- liquid
      sections 'system-group'
      if settings.enable_compare_popup
        render 'compare-offcanvas'
      endif
      render 'system-bottom'
      if settings.custom_html_footer != blank
        echo settings.custom_html_footer
      endif
      render 'structured-data'
    -%}
   {%- endunless -%}
  
  {%- render 'baadmay-script' -%}

  {%- comment -%}Remove duplicate Product ld+json from third-party apps (e.g. Judge.me){%- endcomment -%}
  
</body>
</html>
